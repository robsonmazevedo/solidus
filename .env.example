# Copie este arquivo para .env e ajuste os valores
# O arquivo .env nunca deve ser versionado

# ── Ambiente ─────────────────────────────────────────────────────────────

APP_ENVIRONMENT=Development

# ── PostgreSQL ───────────────────────────────────────────────────────────

POSTGRES_USER=solidus
POSTGRES_INTERNAL_PORT=5432

POSTGRES_REGISTROS_HOST=postgres-registros
POSTGRES_REGISTROS_DB=registros
POSTGRES_REGISTROS_PASSWORD=troque_em_producao
REGISTROS_CONNECTION_STRING=Host=postgres-registros;Port=5432;Database=registros;Username=solidus;Password=troque_em_producao
PORT_POSTGRES_REGISTROS=5432

POSTGRES_POSICAO_HOST=postgres-posicao
POSTGRES_POSICAO_DB=posicao
POSTGRES_POSICAO_PASSWORD=troque_em_producao
POSICAO_CONNECTION_STRING=Host=postgres-posicao;Port=5432;Database=posicao;Username=solidus;Password=troque_em_producao
PORT_POSTGRES_POSICAO=5433

# ── RabbitMQ ─────────────────────────────────────────────────────────────

RABBITMQ_HOST=rabbitmq
RABBITMQ_USER=solidus
RABBITMQ_PASSWORD=troque_em_producao
PORT_RABBITMQ=5672
PORT_RABBITMQ_MANAGEMENT=15672
PORT_RABBITMQ_PROMETHEUS=15692

# ── Redis ────────────────────────────────────────────────────────────────

REDIS_CONNECTION=redis:6379
REDIS_EXPORTER_ADDR=redis://redis:6379
PORT_REDIS=6379
PORT_REDISINSIGHT=5540
PORT_REDIS_EXPORTER=9121

# ── Jaeger ───────────────────────────────────────────────────────────────

OTLP_ENDPOINT=http://jaeger:4317
PORT_JAEGER_UI=16686
PORT_JAEGER_GRPC=4317
PORT_JAEGER_HTTP=4318

# ── Prometheus ───────────────────────────────────────────────────────────

PROMETHEUS_ENDPOINT=http://+:8082/
PORT_PROMETHEUS=9090

# ── Grafana ──────────────────────────────────────────────────────────────

GRAFANA_PASSWORD=troque_em_producao
PORT_GRAFANA=3000

# ── SonarQube ────────────────────────────────────────────────────────────

PORT_SONARQUBE=9000

# ── pgAdmin ──────────────────────────────────────────────────────────────

PGADMIN_EMAIL=admin@solidus.dev
PGADMIN_PASSWORD=troque_em_producao
PORT_PGADMIN=8084

# ── JWT ──────────────────────────────────────────────────────────────────

JWT_SECRET=troque_em_producao_use_256_bits
JWT_ISSUER=solidus

# ── Serviços .NET ────────────────────────────────────────────────────────

PORT_REGISTROS_API=8080
PORT_POSICAO_API=8081
PORT_PROCESSOR_METRICS=8082
