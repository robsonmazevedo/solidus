{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    },
    "Console": {
      "FormatterName": "json",
      "FormatterOptions": {
        "SingleLine": true,
        "IncludeScopes": true,
        "TimestampFormat": "yyyy-MM-ddTHH:mm:ssZ",
        "UseUtcTimestamp": true
      }
    }
  },
  "AllowedHosts": "*",
  "RateLimit": {
    "PermitLimit": 100
  }
}
